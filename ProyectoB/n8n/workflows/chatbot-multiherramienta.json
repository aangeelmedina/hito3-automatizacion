        "jsCode": "const raw = $input.first().json.response;\nconst clean = raw.replace(/```json|```/g, \"\").trim();\nconst parsed = JSON.parse(clean);\n\nreturn [{\n  json: {\n    valor: {\n      intencion: parsed.intencion.toLowerCase(),\n      ubicacion: parsed.ubicacion || null\n    },\n    mensaje_original: $('Webhook').first().json.body.mensaje\n  }\n}];"
