    {
      "parameters": {
        "jsCode": "const mensaje = $input.first().json.mensaje_original\n\n// Limpiar el mensaje para obtener el tema\nconst tema = mensaje\n  .replace(/qué es|quien fue|quién fue|cuéntame sobre|háblame de|información sobre|dime sobre|qué sabes de/gi, '')\n  .trim();\n\n// Capitalizar primera letra\nconst temaFinal = tema.charAt(0).toUpperCase() + tema.slice(1);\n\nreturn [{\n  json: {\n    mensaje_original: mensaje,\n    tema: temaFinal\n  }\n}];"
